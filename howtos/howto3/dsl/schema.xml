<?xml version="1.0" encoding="UTF-8"?>
<schema name="howto3" endian="big">
    <ns name="prot1">
        <fields>
            <int name="EscField" type="uint8" defaultValue="0x10" />
        </fields>

        <interface name="Prot1Interface" />

        <message name="Prot1PseudoMsg" id="0">
            <data name="Data" />
        </message>

        <frame name="Prot1Frame">
            <sync name="Prefix" seekField="true" escField="prot1.EscField">
                <field>
                    <int name="SyncField" type="uint8" defaultValue="0x02" />
                </field>
            </sync>
            <id name="Id">
                <int name="IdField" type="uint8" defaultValue="0" pseudo="true" />
            </id>
            <payload name="Data" />
            <sync name="Suffix" seekField="true" from="Id" escField="prot1.EscField">
                <field>
                    <int name="SyncField" type="uint8" defaultValue="0x03" />
                </field>
            </sync>
        </frame>
    </ns>

    <ns name="prot2">
        <fields>
            <string name="Msg1Name" defaultValue="Message 1" />
            <string name="Msg2Name" defaultValue="Message 2" />
            <string name="Msg3Name" defaultValue="Message 3" />
            <string name="Msg4Name" defaultValue="Message 4" />

            <enum name="MsgId" type="uint8" semanticType="messageId">
                <validValue name="M1" val="1" displayName="^prot2.Msg1Name" />
                <validValue name="M2" val="2" displayName="^prot2.Msg2Name" />
                <validValue name="M3" val="3" displayName="^prot2.Msg3Name" />
                <validValue name="M4" val="4" displayName="^prot2.Msg4Name" />
            </enum>
        </fields>

        <frame name="Prot2Frame">
            <id name="Id" field="prot2.MsgId" />
            <payload name="Data" />
        </frame>

        <interface name="Prot2Interface" />

        <message name="Msg1" id="prot2.MsgId.M1" displayName="^prot2.Msg1Name">
            <string name="F1" />
        </message>

        <message name="Msg2" id="prot2.MsgId.M2" displayName="^prot2.Msg2Name">
            <data name="F1" />
        </message>

        <message name="Msg3" id="prot2.MsgId.M3" displayName="^prot2.Msg3Name">
            <int name="F1" type="uint16" />
        </message>
    </ns>
</schema>
